rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // For this app, we trust the specific user email joyk1838@gmail.com
      // Note: In production, we would use an 'admins' collection lookup.
      // But we must follow the rule: "Include User email from runtime as an admin"
      return isSignedIn() && request.auth.token.email == 'joyk1838@gmail.com' && isEmailVerified();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity validation helpers
    function isValidBrand(data) {
      return data.keys().hasAll(['name', 'image', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.image is string && data.image.size() > 0 && data.image.size() <= 500 &&
             data.order is number;
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['name', 'role', 'image', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() <= 100 &&
             data.image is string && data.image.size() > 0 && data.image.size() <= 500 &&
             data.order is number;
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['url', 'title', 'uploadedAt']) &&
             data.url is string && data.url.size() > 0 && data.url.size() <= 500 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100;
    }

    // Global deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBrand(request.resource.data);
    }

    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTeamMember(request.resource.data);
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidGalleryItem(request.resource.data);
    }
  }
}
